import Erdos1038.CircleTerminalShellEnergy
import Mathlib.Analysis.SpecialFunctions.Integrability.LogMeromorphic

/-!
# Bathtub comparison for centered circle densities

This file isolates the fixed-mass analytic step after terminal-shell
compression.  The first result is a measure-theoretic bathtub principle for
`[0,1]`-valued densities and a weight separated by one threshold set.
-/

set_option warningAsError true

open Metric Set MeasureTheory
open scoped ENNReal

namespace Erdos1038

noncomputable section

local notation "AngleCircle" => AddCircle (2 * Real.pi)

local instance : Fact (0 < 2 * Real.pi) := ⟨Real.two_pi_pos⟩

/-- A `[0,1]`-valued density with the same mass as `A` maximizes its
integral against a weight whose values on `A` dominate all values outside
`A` when it is replaced by the indicator of `A`. -/
theorem lintegral_density_mul_le_setLIntegral_of_threshold
    {X : Type*} [MeasurableSpace X] {mu : Measure X}
    {A : Set X} (hA : MeasurableSet A) (hmuA : mu A ≠ ∞)
    {f : X → ℝ} (hf : Measurable f)
    (hf0 : ∀ x, 0 ≤ f x) (hf1 : ∀ x, f x ≤ 1)
    (hmass : (∫⁻ x, ENNReal.ofReal (f x) ∂mu) = mu A)
    {w : X → ℝ≥0∞} (hw : Measurable w) (threshold : ℝ≥0∞)
    (hwInside : ∀ x ∈ A, threshold ≤ w x)
    (hwOutside : ∀ x ∉ A, w x ≤ threshold) :
    (∫⁻ x, ENNReal.ofReal (f x) * w x ∂mu) ≤
      ∫⁻ x in A, w x ∂mu := by
  let F : X → ℝ≥0∞ := fun x ↦ ENNReal.ofReal (f x)
  let G : X → ℝ≥0∞ := fun x ↦ ENNReal.ofReal (1 - f x)
  have hF : Measurable F := hf.ennreal_ofReal
  have hG : Measurable G :=
    (measurable_const.sub hf).ennreal_ofReal
  have hFleOne : ∀ x, F x ≤ 1 := by
    intro x
    simpa only [F, ENNReal.ofReal_one] using
      ENNReal.ofReal_le_ofReal (hf1 x)
  have hFG : ∀ x, F x + G x = 1 := by
    intro x
    rw [← ENNReal.ofReal_add (hf0 x) (sub_nonneg.mpr (hf1 x))]
    norm_num
  have hFAle : (∫⁻ x in A, F x ∂mu) ≤ mu A := by
    calc
      (∫⁻ x in A, F x ∂mu) ≤ ∫⁻ _x in A, (1 : ℝ≥0∞) ∂mu :=
        setLIntegral_mono' hA fun x _hx ↦ hFleOne x
      _ = mu A := by simp
  have hFAfinite : (∫⁻ x in A, F x ∂mu) ≠ ∞ :=
    ne_top_of_le_ne_top hmuA hFAle
  have hmassSplit :
      (∫⁻ x in A, F x ∂mu) + (∫⁻ x in Aᶜ, F x ∂mu) = mu A := by
    rw [lintegral_add_compl F hA]
    simpa only [F] using hmass
  have hmissingSplit :
      (∫⁻ x in A, F x ∂mu) + (∫⁻ x in A, G x ∂mu) = mu A := by
    calc
      (∫⁻ x in A, F x ∂mu) + (∫⁻ x in A, G x ∂mu) =
          ∫⁻ x in A, F x + G x ∂mu := by
        rw [lintegral_add_left hF]
      _ = ∫⁻ _x in A, (1 : ℝ≥0∞) ∂mu := by
        apply setLIntegral_congr_fun hA
        intro x _hx
        exact hFG x
      _ = mu A := by simp
  have hmassMissing :
      (∫⁻ x in Aᶜ, F x ∂mu) = ∫⁻ x in A, G x ∂mu := by
    apply (ENNReal.add_right_inj hFAfinite).mp
    exact hmassSplit.trans hmissingSplit.symm
  rw [← lintegral_add_compl (fun x ↦ F x * w x) hA]
  calc
    (∫⁻ x in A, F x * w x ∂mu) +
          (∫⁻ x in Aᶜ, F x * w x ∂mu) ≤
        (∫⁻ x in A, F x * w x ∂mu) +
          (∫⁻ x in Aᶜ, F x * threshold ∂mu) := by
      apply add_le_add le_rfl
      apply setLIntegral_mono' hA.compl
      intro x hx
      exact mul_le_mul_right (hwOutside x hx) (F x)
    _ = (∫⁻ x in A, F x * w x ∂mu) +
          (∫⁻ x in A, G x * threshold ∂mu) := by
      rw [lintegral_mul_const threshold hF,
        lintegral_mul_const threshold hG, hmassMissing]
    _ ≤ (∫⁻ x in A, F x * w x ∂mu) +
          (∫⁻ x in A, G x * w x ∂mu) := by
      apply add_le_add le_rfl
      apply setLIntegral_mono' hA
      intro x hx
      exact mul_le_mul_right (hwInside x hx) (G x)
    _ = ∫⁻ x in A, F x * w x + G x * w x ∂mu := by
      rw [lintegral_add_left (hF.mul hw)]
    _ = ∫⁻ x in A, w x ∂mu := by
      apply setLIntegral_congr_fun hA
      intro x _hx
      change F x * w x + G x * w x = w x
      rw [← add_mul, hFG x, one_mul]

/-! ## Centered logarithmic potentials -/

/-- Logarithmic deficit potential generated by a nonnegative circle
density. -/
def circleDensityLogPotential
    (g : AngleCircle → ℝ) (x : AngleCircle) : ℝ≥0∞ :=
  ∫⁻ y, ENNReal.ofReal (g y) *
    ENNReal.ofReal (circleLogDeficitAt x y)

lemma measurable_circleDensityLogPotential
    {g : AngleCircle → ℝ} (hg : Measurable g) :
    Measurable (circleDensityLogPotential g) := by
  unfold circleDensityLogPotential
  apply Measurable.lintegral_prod_right
  exact (hg.comp measurable_snd).ennreal_ofReal.mul
    measurable_uncurry_circleLogDeficitAt_ofReal

/-- One-variable layer cake for a logarithmic deficit potential. -/
theorem circleDensityLogPotential_eq_lintegral_superlevels
    {g : AngleCircle → ℝ} (hg : Measurable g)
    (hg0 : ∀ y, 0 ≤ g y) (x : AngleCircle) :
    circleDensityLogPotential g x =
      ∫⁻ s in Ioi (0 : ℝ),
        ∫⁻ y in {y | s < g y},
          ENNReal.ofReal (circleLogDeficitAt x y) := by
  let kernel : AngleCircle → ℝ≥0∞ :=
    fun y ↦ ENNReal.ofReal (circleLogDeficitAt x y)
  let weighted : Measure AngleCircle := volume.withDensity kernel
  have hkernel : Measurable kernel :=
    (measurable_circleLogDeficitAt x).ennreal_ofReal
  have hlayer := lintegral_eq_lintegral_meas_lt weighted
    (Filter.Eventually.of_forall hg0) hg.aemeasurable
  calc
    circleDensityLogPotential g x =
        ∫⁻ y, kernel y * ENNReal.ofReal (g y) := by
      unfold circleDensityLogPotential kernel
      apply lintegral_congr
      intro y
      rw [mul_comm]
    _ = ∫⁻ y, ENNReal.ofReal (g y) ∂weighted := by
      dsimp only [weighted]
      rw [lintegral_withDensity_eq_lintegral_mul
        volume hkernel hg.ennreal_ofReal]
      rfl
    _ = ∫⁻ s in Ioi (0 : ℝ),
          weighted {y | s < g y} := hlayer
    _ = ∫⁻ s in Ioi (0 : ℝ),
          ∫⁻ y in {y | s < g y},
            ENNReal.ofReal (circleLogDeficitAt x y) := by
      apply setLIntegral_congr_fun measurableSet_Ioi
      intro s _hs
      have hlevel : MeasurableSet {y : AngleCircle | s < g y} :=
        measurableSet_lt measurable_const hg
      dsimp only [weighted, kernel]
      rw [withDensity_apply _ hlevel]

lemma addCircle_dist_zero_coe_eq
    {d : ℝ} (hd : d ∈ Icc (0 : ℝ) Real.pi) :
    dist (0 : AngleCircle) (d : AngleCircle) = d := by
  rw [dist_comm, dist_eq_norm, sub_zero]
  have hnorm := (AddCircle.norm_coe_eq_abs_iff
    (2 * Real.pi) (by positivity)).2 (by
      rw [abs_of_nonneg hd.1, abs_of_pos Real.two_pi_pos]
      linarith [hd.2])
  rw [hnorm, abs_of_nonneg hd.1]

/-- Integrating the logarithmic kernel centered at `x` over an origin-
centered arc depends only on `dist x 0`. -/
theorem lintegral_circleLogDeficitAt_centeredClosedBall
    {r : ℝ} (hr0 : 0 ≤ r) (hrpi : r ≤ Real.pi)
    (x : AngleCircle) :
    (∫⁻ y in closedBall (0 : AngleCircle) r,
        ENNReal.ofReal (circleLogDeficitAt x y)) =
      circleLogArcPotential r (dist x 0) := by
  have hd : dist x 0 ∈ Icc (0 : ℝ) Real.pi :=
    ⟨dist_nonneg, addCircle_dist_le_pi 0 x⟩
  rw [lintegral_circleLogDeficitAt_closedBall,
    circleLogArcPotential_eq_layerCake]
  apply setLIntegral_congr_fun measurableSet_Ioi
  intro t _ht
  change
    volume
        (closedBall x (circleLogLayerRadius t) ∩
          closedBall (0 : AngleCircle) r) =
      volume
        (closedBall (0 : AngleCircle) (circleLogLayerRadius t) ∩
          closedBall ((dist x 0 : ℝ) : AngleCircle) r)
  rw [volume_inter_addCircle_closedBalls
      (circleLogLayerRadius_nonneg t)
      (circleLogLayerRadius_le_pi t) hr0 hrpi,
    volume_inter_addCircle_closedBalls
      (circleLogLayerRadius_nonneg t)
      (circleLogLayerRadius_le_pi t) hr0 hrpi,
    addCircle_dist_zero_coe_eq hd]

/-- A centered-ball description of every positive superlevel makes the
density potential radial. -/
theorem circleDensityLogPotential_eq_coe_dist
    {g : AngleCircle → ℝ} (hg : Measurable g)
    (hg0 : ∀ y, 0 ≤ g y) (radius : ℝ → ℝ)
    (hradius0 : ∀ s ∈ Ioi (0 : ℝ), 0 ≤ radius s)
    (hradiusPi : ∀ s ∈ Ioi (0 : ℝ), radius s ≤ Real.pi)
    (hsuperlevel : ∀ s ∈ Ioi (0 : ℝ),
      {y | s < g y} =ᵐ[volume]
        closedBall (0 : AngleCircle) (radius s))
    (x : AngleCircle) :
    circleDensityLogPotential g x =
      circleDensityLogPotential g ((dist x 0 : ℝ) : AngleCircle) := by
  have hd : dist x 0 ∈ Icc (0 : ℝ) Real.pi :=
    ⟨dist_nonneg, addCircle_dist_le_pi 0 x⟩
  rw [circleDensityLogPotential_eq_lintegral_superlevels hg hg0,
    circleDensityLogPotential_eq_lintegral_superlevels hg hg0]
  apply setLIntegral_congr_fun measurableSet_Ioi
  intro s hs
  change
    (∫⁻ y in {y | s < g y},
        ENNReal.ofReal (circleLogDeficitAt x y)) =
      ∫⁻ y in {y | s < g y},
        ENNReal.ofReal
          (circleLogDeficitAt ((dist x 0 : ℝ) : AngleCircle) y)
  rw [Measure.restrict_congr_set (hsuperlevel s hs),
    lintegral_circleLogDeficitAt_centeredClosedBall
      (hradius0 s hs) (hradiusPi s hs),
    lintegral_circleLogDeficitAt_centeredClosedBall
      (hradius0 s hs) (hradiusPi s hs),
    dist_comm (((dist x 0 : ℝ) : AngleCircle)) 0,
    addCircle_dist_zero_coe_eq hd]

/-- The logarithmic potential of a density with centered-ball positive
superlevels decreases along the half-circle. -/
theorem circleDensityLogPotential_coe_antitoneOn
    {g : AngleCircle → ℝ} (hg : Measurable g)
    (hg0 : ∀ y, 0 ≤ g y) (radius : ℝ → ℝ)
    (hradius0 : ∀ s ∈ Ioi (0 : ℝ), 0 ≤ radius s)
    (hradiusPi : ∀ s ∈ Ioi (0 : ℝ), radius s ≤ Real.pi)
    (hsuperlevel : ∀ s ∈ Ioi (0 : ℝ),
      {y | s < g y} =ᵐ[volume]
        closedBall (0 : AngleCircle) (radius s)) :
    AntitoneOn
      (fun d : ℝ ↦ circleDensityLogPotential g (d : AngleCircle))
      (Icc (0 : ℝ) Real.pi) := by
  intro d hd e he hde
  change circleDensityLogPotential g (e : AngleCircle) ≤
    circleDensityLogPotential g (d : AngleCircle)
  rw [circleDensityLogPotential_eq_lintegral_superlevels hg hg0,
    circleDensityLogPotential_eq_lintegral_superlevels hg hg0]
  apply setLIntegral_mono' measurableSet_Ioi
  intro s hs
  change
    (∫⁻ y in {y | s < g y},
        ENNReal.ofReal (circleLogDeficitAt (e : AngleCircle) y)) ≤
      ∫⁻ y in {y | s < g y},
        ENNReal.ofReal (circleLogDeficitAt (d : AngleCircle) y)
  rw [Measure.restrict_congr_set (hsuperlevel s hs),
    lintegral_circleLogDeficitAt_centeredClosedBall
      (hradius0 s hs) (hradiusPi s hs),
    lintegral_circleLogDeficitAt_centeredClosedBall
      (hradius0 s hs) (hradiusPi s hs),
    dist_comm ((d : ℝ) : AngleCircle) 0,
    dist_comm ((e : ℝ) : AngleCircle) 0,
    addCircle_dist_zero_coe_eq hd,
    addCircle_dist_zero_coe_eq he]
  exact circleLogArcPotential_antitoneOn
    (hradius0 s hs) (hradiusPi s hs) hd he hde

lemma circleDensityLogDeficit_eq_lintegral_mul_potential
    (f g : AngleCircle → ℝ) :
    circleDensityLogDeficit f g =
      ∫⁻ x, ENNReal.ofReal (f x) * circleDensityLogPotential g x := by
  unfold circleDensityLogDeficit densityKernelEnergy
    circleDensityLogPotential
  apply lintegral_congr
  intro x
  rw [← lintegral_const_mul'
    (ENNReal.ofReal (f x))
    (fun y ↦ ENNReal.ofReal (g y) *
      ENNReal.ofReal (circleLogDeficitAt x y))
    ENNReal.ofReal_ne_top]
  apply lintegral_congr
  intro y
  ac_rfl

theorem circleDensityLogDeficit_comm
    {f g : AngleCircle → ℝ} (hf : Measurable f) (hg : Measurable g) :
    circleDensityLogDeficit f g = circleDensityLogDeficit g f := by
  unfold circleDensityLogDeficit densityKernelEnergy
  let integrand : AngleCircle × AngleCircle → ℝ≥0∞ := fun p ↦
    ENNReal.ofReal (f p.1) * ENNReal.ofReal (g p.2) *
      ENNReal.ofReal (circleLogDeficitAt p.1 p.2)
  have hintegrand : Measurable integrand := by
    unfold integrand
    exact ((hf.comp measurable_fst).ennreal_ofReal.mul
      (hg.comp measurable_snd).ennreal_ofReal).mul
        measurable_uncurry_circleLogDeficitAt_ofReal
  calc
    (∫⁻ x, ∫⁻ y, ENNReal.ofReal (f x) * ENNReal.ofReal (g y) *
          ENNReal.ofReal (circleLogDeficitAt x y)) =
        ∫⁻ y, ∫⁻ x, ENNReal.ofReal (f x) * ENNReal.ofReal (g y) *
          ENNReal.ofReal (circleLogDeficitAt x y) := by
      apply lintegral_lintegral_swap
      exact hintegrand.aemeasurable
    _ = ∫⁻ y, ∫⁻ x, ENNReal.ofReal (g y) * ENNReal.ofReal (f x) *
          ENNReal.ofReal (circleLogDeficitAt y x) := by
      apply lintegral_congr
      intro y
      apply lintegral_congr
      intro x
      have hkernel : circleLogDeficitAt x y = circleLogDeficitAt y x := by
        unfold circleLogDeficitAt
        rw [dist_comm]
      rw [hkernel]
      ac_rfl

/-- Real indicator of the centered arc of radius `r`. -/
def centeredArcIndicator (r : ℝ) (z : AngleCircle) : ℝ :=
  (closedBall (0 : AngleCircle) r).indicator (fun _ ↦ 1) z

lemma measurable_centeredArcIndicator (r : ℝ) :
    Measurable (centeredArcIndicator r) :=
  measurable_const.indicator measurableSet_closedBall

lemma centeredArcIndicator_mem_Icc (r : ℝ) (z : AngleCircle) :
    centeredArcIndicator r z ∈ Icc (0 : ℝ) 1 := by
  by_cases hz : z ∈ closedBall (0 : AngleCircle) r
  · simp [centeredArcIndicator, hz]
  · simp [centeredArcIndicator, hz]

lemma lintegral_centeredArcIndicator (r : ℝ) :
    (∫⁻ z, ENNReal.ofReal (centeredArcIndicator r z)) =
      volume (closedBall (0 : AngleCircle) r) := by
  have hfun : (fun z : AngleCircle ↦
      ENNReal.ofReal (centeredArcIndicator r z)) =
      (closedBall (0 : AngleCircle) r).indicator (fun _ ↦ (1 : ℝ≥0∞)) := by
    funext z
    by_cases hz : z ∈ closedBall (0 : AngleCircle) r
    · simp [centeredArcIndicator, hz]
    · simp [centeredArcIndicator, hz]
  rw [hfun, lintegral_indicator measurableSet_closedBall]
  simp

/-- Positive superlevels of an arc indicator, with the zero-radius null arc
used above level one. -/
def centeredArcIndicatorSuperlevelRadius (r s : ℝ) : ℝ :=
  if s < 1 then r else 0

lemma centeredArcIndicator_superlevel_ae_eq_closedBall
    {r s : ℝ} (hs : 0 < s) :
    {z : AngleCircle | s < centeredArcIndicator r z} =ᵐ[volume]
      closedBall (0 : AngleCircle)
        (centeredArcIndicatorSuperlevelRadius r s) := by
  by_cases hs1 : s < 1
  · have hset : {z : AngleCircle | s < centeredArcIndicator r z} =
        closedBall (0 : AngleCircle) r := by
      ext z
      by_cases hz : z ∈ closedBall (0 : AngleCircle) r
      · simp [centeredArcIndicator, hz, hs1]
      · simp [centeredArcIndicator, hz, not_lt_of_ge hs.le]
    rw [hset]
    simp [centeredArcIndicatorSuperlevelRadius, hs1]
  · have hset : {z : AngleCircle | s < centeredArcIndicator r z} =
        ball (0 : AngleCircle) 0 := by
      ext z
      by_cases hz : z ∈ closedBall (0 : AngleCircle) r
      · simp [centeredArcIndicator, hz, not_lt.mpr (not_lt.mp hs1)]
      · simp [centeredArcIndicator, hz, not_lt_of_ge hs.le]
    rw [hset]
    simpa [centeredArcIndicatorSuperlevelRadius, hs1] using
      (AddCircle.closedBall_ae_eq_ball
        (x := (0 : AngleCircle)) (ε := (0 : ℝ))).symm

lemma circleDensityLogDeficit_centeredArcIndicator_left
    (r : ℝ) (g : AngleCircle → ℝ) :
    circleDensityLogDeficit (centeredArcIndicator r) g =
      ∫⁻ x in closedBall (0 : AngleCircle) r,
        circleDensityLogPotential g x := by
  rw [circleDensityLogDeficit_eq_lintegral_mul_potential]
  have hfun : (fun x : AngleCircle ↦
      ENNReal.ofReal (centeredArcIndicator r x) *
        circleDensityLogPotential g x) =
      (closedBall (0 : AngleCircle) r).indicator
        (circleDensityLogPotential g) := by
    funext x
    by_cases hx : x ∈ closedBall (0 : AngleCircle) r
    · simp [centeredArcIndicator, hx]
    · simp [centeredArcIndicator, hx]
  rw [hfun, lintegral_indicator measurableSet_closedBall]

theorem circleDensityLogDeficit_centeredArcIndicators
    (r s : ℝ) :
    circleDensityLogDeficit
        (centeredArcIndicator r) (centeredArcIndicator s) =
      circleLogTwoArcEnergy r s 0 := by
  rw [circleDensityLogDeficit_centeredArcIndicator_left]
  unfold circleDensityLogPotential circleLogTwoArcEnergy
  apply setLIntegral_congr_fun measurableSet_closedBall
  intro x _hx
  have hfun : (fun y : AngleCircle ↦
      ENNReal.ofReal (centeredArcIndicator s y) *
        ENNReal.ofReal (circleLogDeficitAt x y)) =
      (closedBall (0 : AngleCircle) s).indicator
        (fun y ↦ ENNReal.ofReal (circleLogDeficitAt x y)) := by
    funext y
    by_cases hy : y ∈ closedBall (0 : AngleCircle) s
    · simp [centeredArcIndicator, hy]
    · simp [centeredArcIndicator, hy]
  change
    (∫⁻ y, ENNReal.ofReal (centeredArcIndicator s y) *
        ENNReal.ofReal (circleLogDeficitAt x y)) =
      ∫⁻ y in closedBall (0 : AngleCircle) s,
        ENNReal.ofReal (circleLogDeficitAt x y)
  rw [hfun, lintegral_indicator measurableSet_closedBall]

/-- One-sided bathtub step: if the right density has centered-arc positive
superlevels, replacing the left `[0,1]` density by the equal-mass centered
arc cannot decrease the mixed deficit. -/
theorem circleDensityLogDeficit_le_centeredArcIndicator_left
    {f g : AngleCircle → ℝ} (hf : Measurable f) (hg : Measurable g)
    (hf0 : ∀ x, 0 ≤ f x) (hf1 : ∀ x, f x ≤ 1)
    (hg0 : ∀ y, 0 ≤ g y) {Q : ℝ}
    (hQ : Q ∈ Icc (0 : ℝ) Real.pi)
    (hmass : (∫⁻ x, ENNReal.ofReal (f x)) =
      volume (closedBall (0 : AngleCircle) Q))
    (radius : ℝ → ℝ)
    (hradius0 : ∀ s ∈ Ioi (0 : ℝ), 0 ≤ radius s)
    (hradiusPi : ∀ s ∈ Ioi (0 : ℝ), radius s ≤ Real.pi)
    (hsuperlevel : ∀ s ∈ Ioi (0 : ℝ),
      {y | s < g y} =ᵐ[volume]
        closedBall (0 : AngleCircle) (radius s)) :
    circleDensityLogDeficit f g ≤
      circleDensityLogDeficit (centeredArcIndicator Q) g := by
  rw [circleDensityLogDeficit_eq_lintegral_mul_potential,
    circleDensityLogDeficit_centeredArcIndicator_left]
  apply lintegral_density_mul_le_setLIntegral_of_threshold
    measurableSet_closedBall (measure_ne_top volume _)
    hf hf0 hf1 hmass
    (measurable_circleDensityLogPotential hg)
    (circleDensityLogPotential g (Q : AngleCircle))
  · intro x hx
    have hdist : dist x 0 ∈ Icc (0 : ℝ) Real.pi :=
      ⟨dist_nonneg, addCircle_dist_le_pi 0 x⟩
    have hdistQ : dist x 0 ≤ Q := by
      simpa only [mem_closedBall, dist_comm] using hx
    rw [circleDensityLogPotential_eq_coe_dist hg hg0 radius
      hradius0 hradiusPi hsuperlevel x]
    exact circleDensityLogPotential_coe_antitoneOn hg hg0 radius
      hradius0 hradiusPi hsuperlevel hdist hQ hdistQ
  · intro x hx
    have hdist : dist x 0 ∈ Icc (0 : ℝ) Real.pi :=
      ⟨dist_nonneg, addCircle_dist_le_pi 0 x⟩
    have hQdist : Q ≤ dist x 0 := by
      have hnot : ¬dist x 0 ≤ Q := by
        simpa only [mem_closedBall, dist_comm] using hx
      exact (not_le.mp hnot).le
    rw [circleDensityLogPotential_eq_coe_dist hg hg0 radius
      hradius0 hradiusPi hsuperlevel x]
    exact circleDensityLogPotential_coe_antitoneOn hg hg0 radius
      hradius0 hradiusPi hsuperlevel hQ hdist hQdist

/-- Two-sided fixed-mass bathtub inequality.  Once the right density has
centered-arc positive superlevels, both `[0,1]` densities are dominated by
the pair of centered arc indicators with their respective masses. -/
theorem circleDensityLogDeficit_le_twoArcEnergy_of_centeredSuperlevels
    {f g : AngleCircle → ℝ} (hf : Measurable f) (hg : Measurable g)
    (hf0 : ∀ x, 0 ≤ f x) (hf1 : ∀ x, f x ≤ 1)
    (hg0 : ∀ y, 0 ≤ g y) (hg1 : ∀ y, g y ≤ 1)
    {Q R : ℝ} (hQ : Q ∈ Icc (0 : ℝ) Real.pi)
    (hR : R ∈ Icc (0 : ℝ) Real.pi)
    (hmassF : (∫⁻ x, ENNReal.ofReal (f x)) =
      volume (closedBall (0 : AngleCircle) Q))
    (hmassG : (∫⁻ y, ENNReal.ofReal (g y)) =
      volume (closedBall (0 : AngleCircle) R))
    (radiusG : ℝ → ℝ)
    (hradiusG0 : ∀ s ∈ Ioi (0 : ℝ), 0 ≤ radiusG s)
    (hradiusGPi : ∀ s ∈ Ioi (0 : ℝ), radiusG s ≤ Real.pi)
    (hsuperlevelG : ∀ s ∈ Ioi (0 : ℝ),
      {y | s < g y} =ᵐ[volume]
        closedBall (0 : AngleCircle) (radiusG s)) :
    circleDensityLogDeficit f g ≤ circleLogTwoArcEnergy Q R 0 := by
  let radiusQ : ℝ → ℝ :=
    centeredArcIndicatorSuperlevelRadius Q
  have hradiusQ0 : ∀ s ∈ Ioi (0 : ℝ), 0 ≤ radiusQ s := by
    intro s _hs
    dsimp only [radiusQ, centeredArcIndicatorSuperlevelRadius]
    split_ifs
    · exact hQ.1
    · exact le_rfl
  have hradiusQPi : ∀ s ∈ Ioi (0 : ℝ), radiusQ s ≤ Real.pi := by
    intro s _hs
    dsimp only [radiusQ, centeredArcIndicatorSuperlevelRadius]
    split_ifs
    · exact hQ.2
    · exact Real.pi_pos.le
  have hsuperlevelQ : ∀ s ∈ Ioi (0 : ℝ),
      {y | s < centeredArcIndicator Q y} =ᵐ[volume]
        closedBall (0 : AngleCircle) (radiusQ s) := by
    intro s hs
    exact centeredArcIndicator_superlevel_ae_eq_closedBall hs
  calc
    circleDensityLogDeficit f g ≤
        circleDensityLogDeficit (centeredArcIndicator Q) g :=
      circleDensityLogDeficit_le_centeredArcIndicator_left
        hf hg hf0 hf1 hg0 hQ hmassF radiusG
        hradiusG0 hradiusGPi hsuperlevelG
    _ = circleDensityLogDeficit g (centeredArcIndicator Q) :=
      circleDensityLogDeficit_comm
        (measurable_centeredArcIndicator Q) hg
    _ ≤ circleDensityLogDeficit
        (centeredArcIndicator R) (centeredArcIndicator Q) :=
      circleDensityLogDeficit_le_centeredArcIndicator_left
        hg (measurable_centeredArcIndicator Q)
        hg0 hg1 (fun y ↦ (centeredArcIndicator_mem_Icc Q y).1)
        hR hmassG radiusQ hradiusQ0 hradiusQPi hsuperlevelQ
    _ = circleDensityLogDeficit
        (centeredArcIndicator Q) (centeredArcIndicator R) :=
      circleDensityLogDeficit_comm
        (measurable_centeredArcIndicator R)
        (measurable_centeredArcIndicator Q)
    _ = circleLogTwoArcEnergy Q R 0 :=
      circleDensityLogDeficit_centeredArcIndicators Q R

/-! ## Finiteness of the centered arc energy -/

theorem integrable_circleLogDeficit :
    Integrable circleLogDeficit (volume : Measure AngleCircle) := by
  let F : ℝ → ℝ := fun q ↦
    -Real.log (Real.sin (|q| / 2))
  have hbase : IntervalIntegrable
      (fun q : ℝ ↦ Real.log (Real.sin (q / 2))) volume 0 Real.pi := by
    have h := (intervalIntegrable_log_sin
      (a := (0 : ℝ)) (b := Real.pi / 2)).comp_mul_left
        (c := (1 / 2 : ℝ))
    convert h using 1
    · funext q
      dsimp only [Function.comp_apply]
      congr 2
      ring
    · norm_num
    · ring
  have hpos : IntervalIntegrable F volume 0 Real.pi := by
    apply hbase.neg.congr
    intro q hq
    rw [uIoc_of_le Real.pi_pos.le] at hq
    dsimp only [F]
    simp only [Pi.neg_apply]
    rw [abs_of_nonneg hq.1.le]
  have hnegComp : IntervalIntegrable (fun q ↦ F (-q))
      volume (-Real.pi) 0 := by
    have h := (hpos.comp_sub_left 0).symm
    simpa only [zero_sub, neg_zero] using h
  have hneg : IntervalIntegrable F volume (-Real.pi) 0 := by
    apply hnegComp.congr
    intro q _hq
    dsimp only [F]
    rw [abs_neg]
  have hwhole : IntervalIntegrable F volume (-Real.pi) Real.pi :=
    hneg.trans hpos
  have hFOn : Integrable F
      ((volume : Measure ℝ).restrict (Ioc (-Real.pi) Real.pi)) :=
    (intervalIntegrable_iff_integrableOn_Ioc_of_le
      (by linarith [Real.pi_pos] : -Real.pi ≤ Real.pi)).mp hwhole
  have hpreimage : Integrable
      (fun q : ℝ ↦ circleLogDeficit (q : AngleCircle))
      ((volume : Measure ℝ).restrict (Ioc (-Real.pi) Real.pi)) := by
    apply hFOn.congr
    filter_upwards
      [ae_restrict_mem (measurableSet_Ioc :
        MeasurableSet (Ioc (-Real.pi) Real.pi))] with q hq
    have hnorm : ‖(q : AngleCircle)‖ = |q| := by
      apply (AddCircle.norm_coe_eq_abs_iff
        (2 * Real.pi) (by positivity)).2
      rw [abs_of_pos Real.two_pi_pos]
      apply abs_le.2
      constructor <;> nlinarith [hq.1, hq.2]
    unfold circleLogDeficit circleLogDeficitAt
    dsimp only [F]
    rw [dist_eq_norm, sub_zero, hnorm]
  have hsource : Integrable
      (circleLogDeficit ∘ ((↑) : ℝ → AngleCircle))
      ((volume : Measure ℝ).restrict
        (Ioc (-Real.pi) (-Real.pi + 2 * Real.pi))) := by
    have hinterval : Ioc (-Real.pi) (-Real.pi + 2 * Real.pi) =
        Ioc (-Real.pi) Real.pi := by
      congr 1
      ring
    rw [hinterval]
    simpa only [Function.comp_apply] using hpreimage
  exact ((AddCircle.measurePreserving_mk
    (2 * Real.pi) (-Real.pi)).integrable_comp
      measurable_circleLogDeficit.aestronglyMeasurable).mp hsource

lemma lintegral_circleLogDeficitAt_univ (x : AngleCircle) :
    (∫⁻ y, ENNReal.ofReal (circleLogDeficitAt x y)) =
      ∫⁻ y, ENNReal.ofReal (circleLogDeficit y) := by
  have hpreserving := measurePreserving_sub_right
    (volume : Measure AngleCircle) x
  have hcomp := hpreserving.lintegral_comp
    measurable_circleLogDeficit.ennreal_ofReal
  simpa only [circleLogDeficit, circleLogDeficitAt, Function.comp_apply,
    dist_eq_norm, sub_zero] using hcomp

theorem circleLogTwoArcEnergy_ne_top (r s d : ℝ) :
    circleLogTwoArcEnergy r s d ≠ ∞ := by
  let total : ℝ≥0∞ :=
    ∫⁻ y : AngleCircle, ENNReal.ofReal (circleLogDeficit y)
  have htotal : total ≠ ∞ := by
    exact (lintegral_ofReal_ne_top_iff_integrable
      measurable_circleLogDeficit.aestronglyMeasurable
      (Filter.Eventually.of_forall circleLogDeficit_nonneg)).2
        integrable_circleLogDeficit
  have hvolume : volume (closedBall (0 : AngleCircle) r) ≠ ∞ :=
    measure_ne_top volume _
  have hbound : circleLogTwoArcEnergy r s d ≤
      volume (closedBall (0 : AngleCircle) r) * total := by
    unfold circleLogTwoArcEnergy
    calc
      (∫⁻ x in closedBall (0 : AngleCircle) r,
          ∫⁻ y in closedBall (d : AngleCircle) s,
            ENNReal.ofReal (circleLogDeficitAt x y)) ≤
          ∫⁻ _x in closedBall (0 : AngleCircle) r, total := by
        apply setLIntegral_mono' measurableSet_closedBall
        intro x _hx
        calc
          (∫⁻ y in closedBall (d : AngleCircle) s,
              ENNReal.ofReal (circleLogDeficitAt x y)) ≤
              ∫⁻ y, ENNReal.ofReal (circleLogDeficitAt x y) :=
            setLIntegral_le_lintegral _ _
          _ = total := lintegral_circleLogDeficitAt_univ x
      _ = volume (closedBall (0 : AngleCircle) r) * total := by
        simp [mul_comm]
  exact ne_top_of_le_ne_top (ENNReal.mul_ne_top hvolume htotal) hbound

