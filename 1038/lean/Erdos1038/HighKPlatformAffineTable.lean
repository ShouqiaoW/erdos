/-- The 264 adjacent cells cover the full affine parameter interval. -/
theorem tableCovers {k : ℝ}
    (hk : k ∈ Icc (gridStart : ℝ) (gridEnd : ℝ)) :
    ∃ i : Fin cellCount,
      k ∈ Icc (gridKLo i : ℝ) (gridKHi i : ℝ) :=
  exists_gridCell hk

/-- The exact target length belongs to the enclosure checked by every cell. -/
theorem L_mem_highKAffineEllBox :
    HighKPlatformAffineCell.ellBox.Contains Erdos1038.L := by
  simpa [HighKPlatformAffineCell.ellBox, RatInterval.Contains] using
    And.intro Erdos1038.oneCut_global_certificate.2.2.2.2.1.le
      Erdos1038.oneCut_global_certificate.2.2.2.2.2.le

/-- Calibration on the globally selected affine crossing pair throughout the
complete interval `36/25 ≤ k ≤ 21/10`. -/
theorem affineCalibration_on_fullRange
    {ell : ℝ} (hell : HighKPlatformAffineCell.ellBox.Contains ell) :
    ∀ k : Icc (affineKBox.lo : ℝ) (affineKBox.hi : ℝ),
      PlatformAffineCalibration k (highKPlatformEdge .affine k)
        (affineCrossingPair.xMinus k) (affineCrossingPair.xPlus k)
        (-1 / platformExteriorWx k (highKPlatformEdge .affine k)
          (affineCrossingPair.xMinus k))
        (1 / platformExteriorWx k (highKPlatformEdge .affine k)
          (affineCrossingPair.xPlus k))
        (platformEffectiveConstant ell k (highKPlatformEdge .affine k)
          (affineCrossingPair.xMinus k) (affineCrossingPair.xPlus k)
          (-1 / platformExteriorWx k (highKPlatformEdge .affine k)
            (affineCrossingPair.xMinus k))
          (1 / platformExteriorWx k (highKPlatformEdge .affine k)
            (affineCrossingPair.xPlus k))) := by
  intro k
  have hkGrid : (k : ℝ) ∈ Icc (gridStart : ℝ) (gridEnd : ℝ) := by
    simpa [gridStart, gridEnd, affineKBox] using k.property
  obtain ⟨i, hi⟩ := tableCovers hkGrid
  let localK : Icc ((data i).kLo : ℝ) ((data i).kHi : ℝ) :=
    ⟨k, by simpa [data] using hi⟩
  have h :=
    Erdos1038.HighKPlatformAffineCell.affineCalibration_along_globalCrossingPair
      (data i) (rawChecks i) hell localK
  simpa [localK] using h

end Erdos1038.HighKPlatformAffineTable

namespace Erdos1038

/-- Closed affine-regime certificate in the exact form consumed by the final
numerical-cover assembly. -/
theorem highKAffineGlobalCalibrationCertificate :
    HighKAffineGlobalCalibrationCertificate :=
  HighKPlatformAffineTable.affineCalibration_on_fullRange
    HighKPlatformAffineTable.L_mem_highKAffineEllBox

end Erdos1038
