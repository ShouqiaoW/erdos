/-- All 840 generated cells satisfy their exact crossing and scalar checks. -/
theorem tableCertificate : TableCertificate table where
  cell i := by
    rw [← chunkIndex_chunkOf_localOf i]
    exact matrixCertificate (chunkOf i) (localOf i)

def asGlobalParameter
    (k : Icc (gridStart : ℝ) (gridEnd : ℝ)) :
    Icc (constantKBox.lo : ℝ) (constantKBox.hi : ℝ) :=
  ⟨k, by
    simpa [gridStart, gridEnd, constantKBox] using k.property⟩

/-- Exact calibration for every `k` in the complete constant regime, on the
single globally selected crossing pair. -/
theorem constantCalibration_on_fullRange
    {ell : ℝ}
    (hell : ellBox.Contains ell) :
    ∀ k : Icc (gridStart : ℝ) (gridEnd : ℝ),
      PlatformConstantEdgeCalibration k (highKPlatformEdge .constant k)
        (constantCrossingPair.xMinus (asGlobalParameter k))
        (constantCrossingPair.xPlus (asGlobalParameter k))
        (-1 / platformExteriorWx k (highKPlatformEdge .constant k)
          (constantCrossingPair.xMinus (asGlobalParameter k)))
        (1 / platformExteriorWx k (highKPlatformEdge .constant k)
          (constantCrossingPair.xPlus (asGlobalParameter k)))
        (platformEffectiveConstant ell k (highKPlatformEdge .constant k)
          (constantCrossingPair.xMinus (asGlobalParameter k))
          (constantCrossingPair.xPlus (asGlobalParameter k))
          (-1 / platformExteriorWx k (highKPlatformEdge .constant k)
            (constantCrossingPair.xMinus (asGlobalParameter k)))
          (1 / platformExteriorWx k (highKPlatformEdge .constant k)
            (constantCrossingPair.xPlus (asGlobalParameter k)))) := by
  intro k
  obtain ⟨i, hi⟩ := exists_gridCell k.property
  let localK : Icc ((table.cell i).kLo : ℝ) ((table.cell i).kHi : ℝ) :=
    ⟨k, by simpa [Table.cell] using hi⟩
  have hcal := constantCalibration_along_globalCrossingPair
    (table.cell i) (tableCertificate.cell i) hell localK
  simpa [asGlobalParameter, localK] using hcal

end Erdos1038.HighKPlatformConstantTableCertificate
