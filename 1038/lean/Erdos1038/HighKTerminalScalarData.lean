def mkTail (shift : Nat)
    (qlo qhi rlo rhi qrlo qrhi zplo zphi zmlo zmhi : Rat) : TailQBox :=
  ⟨shift, ⟨qlo, qhi⟩, ⟨rlo, rhi⟩, ⟨qrlo, qrhi⟩,
