def mkRefined (shift : Nat)
    (qlo qhi rlo rhi qrlo qrhi zplo zphi zmlo zmhi qCap rCap : Rat) :
    RefinedData :=
  ⟨mkTail shift qlo qhi rlo rhi qrlo qrhi zplo zphi zmlo zmhi,
    qCap, rCap⟩

